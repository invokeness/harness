# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: status
# ═══════════════════════════════════════════════════════════════════════════════
cmd_status() {
  local harness_dir=".harness"

  if [[ ! -d "$harness_dir" ]]; then
    echo -e "${DIM}No .harness/ directory found. Run 'harness init' first.${NC}"
    exit 1
  fi

  if [[ ! -f "${harness_dir}/progress.md" ]]; then
    echo -e "${BOLD}Harness Status${NC}"
    echo ""
    echo -e "  ${DIM}No runs yet.${NC}"
    echo -e "  Run: ${BOLD}harness run \"your requirements\"${NC}"
    echo ""

    # Show config if exists
    if [[ -f "${harness_dir}/harness.config.json" ]]; then
      echo -e "${BOLD}Configuration:${NC}"
      local json
      json="$(cat "${harness_dir}/harness.config.json")"
      echo -e "  Backend: ${CYAN}$(json_get "$json" "backend")${NC}"
      echo -e "  Model:   ${CYAN}$(json_get "$json" "model")${NC}"
      echo ""
    fi
    exit 0
  fi

  banner "Harness Status"

  # Parse progress.md
  local progress
  progress="$(cat "${harness_dir}/progress.md")"

  # Extract key info
  local status run_id sprint_num
  status=$(echo "$progress" | grep '^\*\*Status\*\*' | sed 's/.*: //')
  run_id=$(echo "$progress" | grep '^\*\*Run ID\*\*' | sed 's/.*: //')
  sprint_num=$(echo "$progress" | head -3 | grep -o 'Sprint [0-9]*' | head -1)

  echo -e "  Run ID:  ${CYAN}${run_id:-unknown}${NC}"
  echo -e "  Sprint:  ${BOLD}${sprint_num:-unknown}${NC}"

  # Color-code status
  case "$status" in
    *COMPLETE*) echo -e "  Status:  ${GREEN}${status}${NC}" ;;
    *FAILED*)   echo -e "  Status:  ${RED}${status}${NC}" ;;
    *CAPPED*)   echo -e "  Status:  ${YELLOW}${status}${NC}" ;;
    *)          echo -e "  Status:  ${CYAN}${status}${NC}" ;;
  esac
  echo ""

  # Show completed sprints
  local sprint_count
  sprint_count=$(find "${harness_dir}/sprints" -name "sprint-*-result.md" 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  ${BOLD}Sprints completed:${NC} ${sprint_count}"

  # Show sprint details
  for result in "${harness_dir}/sprints"/sprint-*-result.md; do
    [[ -f "$result" ]] || continue
    local snum
    snum=$(basename "$result" | grep -o '[0-9]*')
    local first_line
    first_line=$(grep -v '^$' "$result" | head -1)
    local feedback="${harness_dir}/sprints/evaluator-feedback-${snum}.md"
    if [[ -f "$feedback" ]] && grep -qi "VERDICT:.*PASS" "$feedback"; then
      echo -e "    ${GREEN}✓${NC} Sprint ${snum}: ${first_line}"
    elif [[ -f "$feedback" ]] && grep -qi "VERDICT:.*FAIL" "$feedback"; then
      echo -e "    ${RED}✗${NC} Sprint ${snum}: ${first_line}"
    else
      echo -e "    ${YELLOW}?${NC} Sprint ${snum}: ${first_line}"
    fi
  done
  echo ""
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: run
# ═══════════════════════════════════════════════════════════════════════════════
cmd_run() {
  local cli_backend="" cli_model="" cli_file="" cli_max_sprints="" cli_max_retries=""
  local user_req=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --backend)  cli_backend="$2"; shift 2 ;;
      --model)    cli_model="$2"; shift 2 ;;
      --file)     cli_file="$2"; shift 2 ;;
      --max-sprints) cli_max_sprints="$2"; shift 2 ;;
      --max-retries) cli_max_retries="$2"; shift 2 ;;
      -h|--help)  usage; exit 0 ;;
      -*)         err "Unknown option: $1"; usage; exit 1 ;;
      *)          user_req="$1"; shift ;;
    esac
  done

  # Load config
  load_config

  # CLI overrides
  local BACKEND="${cli_backend:-$CFG_BACKEND}"
  local MODEL="${cli_model:-$CFG_MODEL}"
  local MAX_SPRINTS="${cli_max_sprints:-$CFG_MAX_SPRINTS}"
  local MAX_SPRINT_RETRIES="${cli_max_retries:-$CFG_MAX_RETRIES}"

  # Get requirements
  if [[ -n "$cli_file" ]]; then
    if [[ ! -f "$cli_file" ]]; then
      err "Requirements file not found: ${cli_file}"
      exit 1
    fi
    user_req="$(cat "$cli_file")"
  fi

  if [[ -z "$user_req" ]]; then
    echo ""
    echo -e "${BOLD}Enter your requirements (then press Enter):${NC}"
    read -r user_req
  fi

  if [[ -z "$user_req" ]]; then
    err "No requirements provided. Exiting."
    exit 1
  fi

  # ─── Initialize .harness if not present ─────────────────────────────────────
  local HARNESS_DIR=".harness"
  if [[ ! -d "$HARNESS_DIR" ]]; then
    log "No .harness/ found. Running init..."
    cmd_init
  fi

  # ─── Setup paths ────────────────────────────────────────────────────────────
  local PROJECT_DIR="$(pwd)"
  local PROMPTS_DIR="${HARNESS_DIR}/prompts"
  local LOGS_DIR="${HARNESS_DIR}/logs"
  local SPRINTS_DIR="${HARNESS_DIR}/sprints"
  local SPEC_FILE="${HARNESS_DIR}/spec.md"
  local PROGRESS_FILE="${HARNESS_DIR}/progress.md"

  mkdir -p "$LOGS_DIR" "$SPRINTS_DIR"

  local RUN_ID="run-$(date '+%Y%m%d-%H%M%S')"
  local RUN_LOG="${LOGS_DIR}/${RUN_ID}.log"

  # Tee all output to log
  exec > >(tee -a "$RUN_LOG") 2>&1

  # ─── Build agent command ────────────────────────────────────────────────────
  build_agent_cmd "$BACKEND" "$MODEL"

  banner "Autonomous Harness: Planner → Generator → Evaluator"
  log "Run ID:      ${RUN_ID}"
  log "Project dir: ${PROJECT_DIR}"
  log "Backend:     ${BACKEND}"
  log "Model:       ${MODEL}"
  log "Max sprints: ${MAX_SPRINTS}"
  log "Max retries: ${MAX_SPRINT_RETRIES}"
  log "Logs:        ${RUN_LOG}"

  log "Requirements: ${user_req}"
  echo "$user_req" > "${HARNESS_DIR}/user-requirements.txt"

  # ─── Helper: Run agent ────────────────────────────────────────────────────
  run_agent() {
    local system_prompt_file="$1"
    local user_message="$2"
    local output_file="$3"
    local log_label="$4"

    local agent_log="${LOGS_DIR}/${RUN_ID}-${log_label}.log"

    log "  Agent: ${log_label}"

    local full_prompt
    full_prompt="Read your system prompt instructions from: ${system_prompt_file}

---

${user_message}"

    local exit_code=0
    if [[ -n "$AGENT_PROMPT_FLAG" ]]; then
      "${AGENT_CMD[@]}" "$AGENT_PROMPT_FLAG" "$full_prompt" \
        2>"$agent_log" \
        > "$output_file" || exit_code=$?
    else
      "${AGENT_CMD[@]}" "$full_prompt" \
        2>"$agent_log" \
        > "$output_file" || exit_code=$?
    fi

    if [[ $exit_code -ne 0 ]] || [[ ! -s "$output_file" ]]; then
      err "Agent ${log_label} failed (exit=${exit_code}). Log: ${agent_log}"
      err "Output content: $(head -5 "$output_file" 2>/dev/null || echo '(empty)')"
      return 1
    fi

    ok "  Agent ${log_label} done -> ${output_file}"
  }

  # ─── Helper: Run generator agent ──────────────────────────────────────────
  run_generator_agent() {
    local system_prompt_file="$1"
    local user_message="$2"
    local output_file="$3"
    local log_label="$4"

    local agent_log="${LOGS_DIR}/${RUN_ID}-${log_label}.log"

    log "  Generator Agent: ${log_label}"

    local full_prompt
    full_prompt="Read your system prompt instructions from: ${system_prompt_file}

---

${user_message}

IMPORTANT: You are running in the project directory: ${PROJECT_DIR}
After implementing, write your sprint result report to STDOUT.
Also write the sprint contract to the specified contract file path using the Write tool."

    local exit_code=0
    if [[ -n "$AGENT_PROMPT_FLAG" ]]; then
      "${AGENT_CMD[@]}" "$AGENT_PROMPT_FLAG" "$full_prompt" \
        2>"$agent_log" \
        > "$output_file" || exit_code=$?
    else
      "${AGENT_CMD[@]}" "$full_prompt" \
        2>"$agent_log" \
        > "$output_file" || exit_code=$?
    fi

    if [[ $exit_code -ne 0 ]] || [[ ! -s "$output_file" ]]; then
      err "Generator ${log_label} failed (exit=${exit_code}). Log: ${agent_log}"
      err "Output content: $(head -5 "$output_file" 2>/dev/null || echo '(empty)')"
      return 1
    fi

    ok "  Generator ${log_label} done -> ${output_file}"
  }

  # ─── Helper: Git info ──────────────────────────────────────────────────────
  get_git_hash() {
    if git rev-parse --git-dir &>/dev/null; then
      git rev-parse --short HEAD 2>/dev/null || echo "no-git"
    else
      echo "no-git"
    fi
  }

  # ─── Helper: Write progress.md ─────────────────────────────────────────────
  write_progress() {
    local sprint_num="$1"
    local status="$2"
    local next_task="$3"
    local known_issues="${4:-none}"

    local completed_list=""
    for i in $(seq 1 "$sprint_num"); do
      local result_file="${SPRINTS_DIR}/sprint-${i}-result.md"
      if [[ -f "$result_file" ]]; then
        completed_list="${completed_list}
- Sprint ${i}: $(head -5 "$result_file" | grep -v '^$' | head -1)"
      fi
    done

    cat > "$PROGRESS_FILE" <<PROGRESS_EOF
# Progress Report — Sprint ${sprint_num}

**Generated**: $(date '+%Y-%m-%d %H:%M:%S')
**Run ID**: ${RUN_ID}
**Git Commit**: $(get_git_hash)
**Status**: ${status}
**Backend**: ${BACKEND}
**Model**: ${MODEL}

## User Requirements
${user_req}

## Spec File
See: ${SPEC_FILE}

## Completed Sprints
${completed_list}

## Current Sprint: ${sprint_num}
Status: ${status}

## Next Task
${next_task}

## Known Issues
${known_issues}

## Files Modified This Run
$(git diff --name-only 2>/dev/null | head -30 || echo "(not a git repo or no changes)")
PROGRESS_EOF

    ok "progress.md updated (sprint ${sprint_num}, ${status})"
  }

  # ═════════════════════════════════════════════════════════════════════════════
  # PHASE 1: PLANNER
  # ═════════════════════════════════════════════════════════════════════════════
  banner "Phase 1: Planner — Generating Spec"

  # Gather existing project context
  local EXISTING_FILES
  EXISTING_FILES="$(find "$PROJECT_DIR" -maxdepth 2 -type d \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/.harness/*' \
    -not -path '*/harness/*' \
    -not -path '*/__pycache__/*' \
    -not -path '*/.venv/*' \
    -not -path '*/.mypy_cache/*' \
    -not -path '*/.ruff_cache/*' \
    2>/dev/null | head -30 || echo "(empty project)")"

  local KEY_FILES
  KEY_FILES="$(find "$PROJECT_DIR" -maxdepth 2 \( -name '*.py' -o -name '*.js' -o -name '*.ts' -o -name '*.go' -o -name '*.rs' \) -type f \
    -not -path '*/__pycache__/*' \
    -not -path '*/.venv/*' \
    -not -path '*/node_modules/*' \
    2>/dev/null | head -20 || echo "")"

  local PLANNER_INPUT="## User Requirements
${user_req}

## Project Directory
${PROJECT_DIR}

## Directory Structure
${EXISTING_FILES}

## Key Source Files
${KEY_FILES}

## Instructions
First use the Read and Glob tools to explore the project structure and understand the codebase.
Then generate a comprehensive spec.md based on the above requirements.
Output ONLY the spec content in Markdown format, nothing else."

  run_agent \
    "${PROMPTS_DIR}/planner.md" \
    "$PLANNER_INPUT" \
    "$SPEC_FILE" \
    "planner"

  # Validate planner output
  if [[ ! -s "$SPEC_FILE" ]] || head -1 "$SPEC_FILE" | grep -qi "error"; then
    err "Planner failed to generate a valid spec. Aborting."
    err "Content: $(head -3 "$SPEC_FILE" 2>/dev/null)"
    exit 1
  fi

  log "Spec generated: $(wc -l < "$SPEC_FILE") lines"

  # ═════════════════════════════════════════════════════════════════════════════
  # PHASE 2: Sprint Loop — Generator → Evaluator
  # ═════════════════════════════════════════════════════════════════════════════
  banner "Phase 2: Sprint Execution Loop"

  local SPRINT_NUM=0
  local TOTAL_START=$SECONDS

  while [[ $SPRINT_NUM -lt $MAX_SPRINTS ]]; do
    SPRINT_NUM=$((SPRINT_NUM + 1))
    local RETRY_COUNT=0
    local SPRINT_PASSED=false

    local SPRINT_START=$SECONDS
    banner "Sprint ${SPRINT_NUM} / max ${MAX_SPRINTS}"

    local SPRINT_RESULT="${SPRINTS_DIR}/sprint-${SPRINT_NUM}-result.md"
    local SPRINT_CONTRACT="${SPRINTS_DIR}/sprint-${SPRINT_NUM}-contract.md"
    local EVALUATOR_FEEDBACK="${SPRINTS_DIR}/evaluator-feedback-${SPRINT_NUM}.md"

    local PREV_FEEDBACK=""

    # ─── Sprint Retry Loop ───────────────────────────────────────────────────
    while [[ $RETRY_COUNT -lt $MAX_SPRINT_RETRIES ]]; do

      log "Sprint ${SPRINT_NUM}, attempt $((RETRY_COUNT + 1))/${MAX_SPRINT_RETRIES}"

      # ─── GENERATOR ──────────────────────────────────────────────────────────
      local GENERATOR_INPUT="## Your Task
You are executing Sprint ${SPRINT_NUM} of the project.

## Key Files (use Read tool to access these)
- **Spec**: ${SPEC_FILE}
- **Sprint Contract Template**: ${PROMPTS_DIR}/sprint-contract-template.md
- **Previous Progress**: ${PROGRESS_FILE}
- **Project Directory**: ${PROJECT_DIR}

## Previous Evaluator Feedback (if any)
${PREV_FEEDBACK}

## Contract File Path
${SPRINT_CONTRACT}

## Instructions
1. Read the spec file first: ${SPEC_FILE}
2. Read the sprint contract template: ${PROMPTS_DIR}/sprint-contract-template.md
3. Write a sprint contract to: ${SPRINT_CONTRACT}
4. Explore the project directory and implement the sprint deliverables.
5. Self-evaluate your work against the contract criteria.
6. Git commit your changes with message: \"sprint-${SPRINT_NUM}: [description]\"
7. Write a detailed sprint result report to STDOUT.

If this sprint completes all work in the spec, include 'ALL SPRINTS COMPLETE' in your output."

      run_generator_agent \
        "${PROMPTS_DIR}/generator.md" \
        "$GENERATOR_INPUT" \
        "$SPRINT_RESULT" \
        "generator-s${SPRINT_NUM}-a$((RETRY_COUNT + 1))"

      # If generator failed, skip evaluator and retry
      if [[ ! -s "$SPRINT_RESULT" ]] || head -1 "$SPRINT_RESULT" | grep -qi "error"; then
        RETRY_COUNT=$((RETRY_COUNT + 1))
        warn "Generator failed (empty or error output), retry ${RETRY_COUNT}/${MAX_SPRINT_RETRIES}"
        PREV_FEEDBACK="Generator crashed or returned an error. Try again."
        if [[ $RETRY_COUNT -ge $MAX_SPRINT_RETRIES ]]; then
          err "Sprint ${SPRINT_NUM} generator failed after ${MAX_SPRINT_RETRIES} attempts!"
          write_progress "$SPRINT_NUM" "FAILED" "Generator keeps failing" "See logs"
        fi
        continue
      fi

      # ─── EVALUATOR ──────────────────────────────────────────────────────────
      log "Evaluator reviewing sprint ${SPRINT_NUM}..."

      local EVALUATOR_INPUT="## Your Task
Evaluate Sprint ${SPRINT_NUM}, Attempt $((RETRY_COUNT + 1)) of ${MAX_SPRINT_RETRIES}.

## Key Files (use Read tool to access these)
- **Spec**: ${SPEC_FILE}
- **Sprint Contract**: ${SPRINT_CONTRACT}
- **Sprint Result Report**: ${SPRINT_RESULT}
- **Project Directory**: ${PROJECT_DIR}

## Instructions
1. Read the sprint contract: ${SPRINT_CONTRACT}
2. Read the sprint result report: ${SPRINT_RESULT}
3. For EACH criterion in the contract, use Read tool to inspect the actual source files.
4. Do NOT trust the Generator's self-assessment — verify by reading code.
5. Be RUTHLESSLY strict.

Output your evaluation in Markdown. End with exactly one of:
  VERDICT: PASS
  VERDICT: FAIL"

      run_agent \
        "${PROMPTS_DIR}/evaluator.md" \
        "$EVALUATOR_INPUT" \
        "$EVALUATOR_FEEDBACK" \
        "evaluator-s${SPRINT_NUM}-a$((RETRY_COUNT + 1))"

      # ─── Check Verdict ──────────────────────────────────────────────────────
      if grep -qi "VERDICT:.*PASS" "$EVALUATOR_FEEDBACK"; then
        ok "Sprint ${SPRINT_NUM} PASSED! (attempt $((RETRY_COUNT + 1)))"
        SPRINT_PASSED=true
        break
      else
        RETRY_COUNT=$((RETRY_COUNT + 1))
        warn "Sprint ${SPRINT_NUM} FAILED (attempt ${RETRY_COUNT}/${MAX_SPRINT_RETRIES})"

        PREV_FEEDBACK="## Evaluator REJECTED your previous attempt.
Read the full feedback here: ${EVALUATOR_FEEDBACK}
You MUST use the Read tool to read that file and address EVERY issue. Do not skip any. Do not argue. Fix them."

        if [[ $RETRY_COUNT -ge $MAX_SPRINT_RETRIES ]]; then
          err "Sprint ${SPRINT_NUM} exhausted all ${MAX_SPRINT_RETRIES} attempts!"
          write_progress "$SPRINT_NUM" "FAILED" \
            "Sprint ${SPRINT_NUM} needs human intervention" \
            "$(tail -30 "$EVALUATOR_FEEDBACK")"
        fi
      fi
    done

    local SPRINT_ELAPSED=$(( SECONDS - SPRINT_START ))
    log "Sprint ${SPRINT_NUM} took ${SPRINT_ELAPSED}s"

    # ─── Post-Sprint ──────────────────────────────────────────────────────────
    if [[ "$SPRINT_PASSED" == "true" ]]; then
      if grep -qi "ALL SPRINTS COMPLETE\|no further sprints\|project complete" "$SPRINT_RESULT"; then
        write_progress "$SPRINT_NUM" "COMPLETE" "All done!" "none"

        local TOTAL_ELAPSED=$(( SECONDS - TOTAL_START ))
        banner "PROJECT COMPLETE"
        ok "Finished after ${SPRINT_NUM} sprint(s) in ${TOTAL_ELAPSED}s"
        ok "Spec:     ${SPEC_FILE}"
        ok "Progress: ${PROGRESS_FILE}"
        ok "Logs:     ${LOGS_DIR}/"
        exit 0
      fi

      write_progress "$SPRINT_NUM" "completed" \
        "Proceed to sprint $((SPRINT_NUM + 1))" "none"
    fi
  done

  # ─── Safety cap ─────────────────────────────────────────────────────────────
  banner "MAX SPRINTS REACHED (${MAX_SPRINTS})"
  write_progress "$SPRINT_NUM" "CAPPED" \
    "Hit max sprint limit. Human review needed." \
    "Stopped at sprint cap."

  local TOTAL_ELAPSED=$(( SECONDS - TOTAL_START ))
  warn "Stopped after ${MAX_SPRINTS} sprints, ${TOTAL_ELAPSED}s total."
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN: Parse subcommand
# ═══════════════════════════════════════════════════════════════════════════════
if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
  init)    cmd_init "$@" ;;
  run)     cmd_run "$@" ;;
  status)  cmd_status "$@" ;;
  version) echo "harness v${VERSION}" ;;
  -h|--help|help) usage ;;
  *)
    err "Unknown command: ${SUBCOMMAND}"
    echo ""
    usage
    exit 1
    ;;
esac
